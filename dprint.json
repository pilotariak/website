{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "includes": [
    "**/*.{ts,tsx,js,jsx,mjs,cjs,astro,html,css,scss,json,md,toml,yaml,yml}"
  ],
  "excludes": [
    "**/node_modules",
    "**/.git",
    "**/dist",
    "**/.astro"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.93.3.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm",
    "https://plugins.dprint.dev/toml-0.6.4.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.13.0.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.18.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
  ],
  "typescript": {},
  "json": {},
  "markdown": {},
  "toml": {},
  "malva": {}
}
