import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { useTranslations, useTranslatedPath } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

const lang = (Astro.currentLocale ?? "en") as Lang;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);
---

<Layout
  title={t("kancha.meta.title")}
  description={t("kancha.meta.description")}
>
  <Nav />
  <main id="main" tabindex="-1">

    <!-- ── Hero ───────────────────────────────────────────────── -->
    <section class="hero" aria-label={t("kancha.hero.ariaLabel")}>
      <div class="hero__gradient" aria-hidden="true">
        <div class="hero__circle hero__circle--1"></div>
        <div class="hero__circle hero__circle--2"></div>
      </div>
      <div class="container hero__inner">
        <div class="hero__content">
          <a href={tp("/")} class="hero__back">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 3L6 8l4 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {t("kancha.hero.back")}
          </a>
          <p class="eyebrow eyebrow--light hero__eyebrow">{t("kancha.hero.eyebrow")}</p>
          <h1 class="hero__title">Kancha</h1>
          <p class="hero__subtitle">
            {t("kancha.hero.subtitle")}
          </p>
          <div class="hero__actions">
            <a href="https://github.com/Pilotariak/kancha" class="btn btn--white">
              {t("kancha.hero.github")}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#comment-ca-marche" class="btn btn--ghost-white">
              {t("kancha.hero.howItWorks")}
            </a>
          </div>
        </div>

        <!-- Phone mockups -->
        <div class="hero__mockups" aria-hidden="true">
          <!-- Screen 1: competition list -->
          <div class="phone phone--back">
            <div class="phone__header">
              <div class="phone__eyebrow">Compétitions</div>
              <div class="phone__title">Toutes les ligues</div>
            </div>
            <div class="phone__body">
              <div class="phone__featured">
                <div class="phone__feat-label">À la une</div>
                <div class="phone__feat-title">Txapelketa 2026</div>
                <div class="phone__feat-cta">Voir les détails →</div>
              </div>
              <div class="phone__card">
                <div class="phone__card-name">Pilotariak Open</div>
                <div class="phone__card-meta">Femmes · 2026</div>
              </div>
              <div class="phone__card">
                <div class="phone__card-name">Winter Cup 2025</div>
                <div class="phone__card-meta">Vétérans · 2025</div>
              </div>
            </div>
          </div>

          <!-- Screen 2: match results by phase -->
          <div class="phone phone--front">
            <div class="phone__header">
              <div class="phone__eyebrow">Tournoi · Résultats</div>
              <div class="phone__title">Txapelketa 2026</div>
            </div>
            <div class="phone__body">
              <div class="phone__divider">
                <div class="phone__divider-line"></div>
                <div class="phone__divider-pill">Poules</div>
                <div class="phone__divider-line"></div>
              </div>
              <div class="phone__match">
                <div class="phone__match-inner">
                  <div class="phone__team-row">
                    <span class="phone__team">Etxeberria / Urruti.</span>
                    <span class="phone__score">40</span>
                  </div>
                  <div class="phone__team-row">
                    <span class="phone__team">Larralde / Bidart</span>
                    <span class="phone__score">27</span>
                  </div>
                </div>
                <div class="phone__match-foot">
                  <span class="phone__pill phone__pill--muted">28/09/2025</span>
                  <span class="phone__phase">P 1</span>
                </div>
              </div>
              <div class="phone__divider">
                <div class="phone__divider-line"></div>
                <div class="phone__divider-pill phone__divider-pill--amber">Finale</div>
                <div class="phone__divider-line"></div>
              </div>
              <div class="phone__match phone__match--final">
                <div class="phone__match-inner">
                  <div class="phone__team-row">
                    <span class="phone__team">M. Etxeberria</span>
                    <span class="phone__score phone__score--big">40</span>
                  </div>
                  <div class="phone__team-row">
                    <span class="phone__team">I. Larralde</span>
                    <span class="phone__score phone__score--big">32</span>
                  </div>
                </div>
                <div class="phone__match-foot">
                  <span class="phone__pill phone__pill--green">23/11/2025</span>
                  <span class="phone__phase">F 1</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── How it works ─────────────────────────────────────────── -->
    <section class="section" id="comment-ca-marche" aria-labelledby="flow-title">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">{t("kancha.flow.eyebrow")}</p>
          <h2 class="section-header__title" id="flow-title">
            {t("kancha.flow.title")}
          </h2>
          <p class="section-header__subtitle">
            {t("kancha.flow.subtitle")}
          </p>
        </div>

        <div class="steps">
          <div class="step reveal reveal--delay-1">
            <div class="step__num">1</div>
            <div class="step__content">
              <h3 class="step__title">{t("kancha.step1.title")}</h3>
              <p class="step__desc">{t("kancha.step1.desc")}</p>
            </div>
          </div>

          <div class="step reveal reveal--delay-2">
            <div class="step__num">2</div>
            <div class="step__content">
              <h3 class="step__title">{t("kancha.step2.title")}</h3>
              <p class="step__desc">{t("kancha.step2.desc")}</p>
            </div>
          </div>

          <div class="step reveal reveal--delay-3">
            <div class="step__num">3</div>
            <div class="step__content">
              <h3 class="step__title">{t("kancha.step3.title")}</h3>
              <p class="step__desc">{t("kancha.step3.desc")}</p>
            </div>
          </div>

          <div class="step step--result reveal reveal--delay-4">
            <div class="step__num step__num--green">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8l4 4 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="step__content">
              <h3 class="step__title">{t("kancha.step4.title")}</h3>
              <p class="step__desc">{t("kancha.step4.desc")}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Leagues ──────────────────────────────────────────────── -->
    <section class="section section--alt" id="ligues" aria-labelledby="leagues-title">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">{t("kancha.leagues.eyebrow")}</p>
          <h2 class="section-header__title" id="leagues-title">
            {t("kancha.leagues.title")}
          </h2>
          <p class="section-header__subtitle">
            {t("kancha.leagues.subtitle")}
          </p>
        </div>

        <div class="leagues reveal reveal--delay-1">
          <div class="league-card league-card--active">
            <div class="league-card__status">
              <span class="badge badge--green">{t("kancha.leagues.badge.available")}</span>
            </div>
            <h3 class="league-card__name">Comité Côte d'Argent Pelote Basque</h3>
            <p class="league-card__id"><code>lcapb</code></p>
          </div>

          <div class="league-card league-card--planned">
            <div class="league-card__status">
              <span class="badge badge--soft">{t("kancha.leagues.badge.planned")}</span>
            </div>
            <h3 class="league-card__name">Comité du Béarn de Pelote</h3>
          </div>

          <div class="league-card league-card--planned">
            <div class="league-card__status">
              <span class="badge badge--soft">{t("kancha.leagues.badge.planned")}</span>
            </div>
            <h3 class="league-card__name">Comité des Landes de Pelote Basque</h3>
          </div>

          <div class="league-card league-card--planned">
            <div class="league-card__status">
              <span class="badge badge--soft">{t("kancha.leagues.badge.planned")}</span>
            </div>
            <h3 class="league-card__name">Comité Territorial Pays Basque</h3>
          </div>

          <div class="league-card league-card--planned">
            <div class="league-card__status">
              <span class="badge badge--soft">{t("kancha.leagues.badge.planned")}</span>
            </div>
            <h3 class="league-card__name">Ligue d'Île-de-France de Pelote Basque</h3>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Features ────────────────────────────────────────────── -->
    <section class="section section--alt" id="features" aria-labelledby="features-title">
      <div class="container">
        <div class="section-header reveal">
          <p class="eyebrow">{t("kancha.features.eyebrow")}</p>
          <h2 class="section-header__title" id="features-title">
            {t("kancha.features.title")}
          </h2>
          <p class="section-header__subtitle">{t("kancha.features.subtitle")}</p>
        </div>
        <div class="feat-grid reveal reveal--delay-1">
          <div class="feat-card">
            <div class="feat-card__icon feat-card__icon--red" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M6 4h2v16H6M18 4h-2v16h2M8 12h8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feat-card__title">{t("kancha.features.f1.title")}</h3>
            <p class="feat-card__desc">{t("kancha.features.f1.desc")}</p>
          </div>
          <div class="feat-card">
            <div class="feat-card__icon feat-card__icon--amber" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75"/>
                <path d="M12 3c0 4.5-3 7.5-3 9s3 4.5 3 9M3.5 9.5h17M3.5 14.5h17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feat-card__title">{t("kancha.features.f2.title")}</h3>
            <p class="feat-card__desc">{t("kancha.features.f2.desc")}</p>
          </div>
          <div class="feat-card">
            <div class="feat-card__icon feat-card__icon--green" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M4 6h16M7 12h10M10 18h4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feat-card__title">{t("kancha.features.f3.title")}</h3>
            <p class="feat-card__desc">{t("kancha.features.f3.desc")}</p>
          </div>
          <div class="feat-card">
            <div class="feat-card__icon feat-card__icon--red" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M2 8l10-5 10 5-10 5L2 8z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
                <path d="M2 13l10 5 10-5M2 18l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="feat-card__title">{t("kancha.features.f4.title")}</h3>
            <p class="feat-card__desc">{t("kancha.features.f4.desc")}</p>
          </div>
          <div class="feat-card">
            <div class="feat-card__icon feat-card__icon--amber" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.75"/>
                <path d="M3 10h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feat-card__title">{t("kancha.features.f5.title")}</h3>
            <p class="feat-card__desc">{t("kancha.features.f5.desc")}</p>
          </div>
          <div class="feat-card">
            <div class="feat-card__icon feat-card__icon--green" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="feat-card__title">{t("kancha.features.f6.title")}</h3>
            <p class="feat-card__desc">{t("kancha.features.f6.desc")}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Download ──────────────────────────────────────────────── -->
    <section class="section" id="download" aria-labelledby="download-title">
      <div class="container">
        <div class="dl-section reveal">
          <p class="eyebrow">{t("kancha.download.eyebrow")}</p>
          <h2 class="dl-section__title" id="download-title">{t("kancha.download.title")}</h2>
          <p class="dl-section__subtitle">{t("kancha.download.subtitle")}</p>
          <div class="store-badges">
            <div class="store-badge">
              <div class="store-badge__icon" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
              </div>
              <div class="store-badge__info">
                <span class="store-badge__name">App Store</span>
                <span class="badge badge--soft">{t("kancha.download.comingSoon")}</span>
              </div>
            </div>
            <div class="store-badge">
              <div class="store-badge__icon store-badge__icon--android" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.523 7.869l1.107-1.92a.229.229 0 00-.4-.223l-1.12 1.94A7.16 7.16 0 0012 6.75a7.16 7.16 0 00-5.11 2.916l-1.12-1.94a.229.229 0 00-.4.223l1.107 1.92A6.937 6.937 0 004.5 14.25h15a6.937 6.937 0 00-1.977-6.381zM8.625 12a.75.75 0 110-1.5.75.75 0 010 1.5zm6.75 0a.75.75 0 110-1.5.75.75 0 010 1.5zM4.5 15.75v5.25a.75.75 0 001.5 0V21h12v-.75a.75.75 0 001.5-.75v-3.75H4.5zm-1.875-1.5h-.75A.75.75 0 001.5 15v3a.75.75 0 001.5 0v-3a.75.75 0 00-.375-.75zm18.75 0a.75.75 0 00-.375.75v3a.75.75 0 001.5 0v-3a.75.75 0 00-.75-.75h-.375z"/>
                </svg>
              </div>
              <div class="store-badge__info">
                <span class="store-badge__name">Google Play</span>
                <span class="badge badge--soft">{t("kancha.download.comingSoon")}</span>
              </div>
            </div>
          </div>
          <a href="https://github.com/Pilotariak/kancha" class="btn btn--primary">
            {t("kancha.download.github")}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Web app ───────────────────────────────────────────────── -->
    <section class="section section--alt" id="web" aria-labelledby="web-title">
      <div class="container">
        <div class="web-callout reveal">
          <div class="web-callout__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75"/>
              <path d="M12 3c0 0-3 3.5-3 9s3 9 3 9M12 3c0 0 3 3.5 3 9s-3 9-3 9M3 12h18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="web-callout__body">
            <p class="eyebrow">{t("kancha.web.eyebrow")}</p>
            <h2 class="web-callout__title" id="web-title">{t("kancha.web.title")}</h2>
            <p class="web-callout__subtitle">{t("kancha.web.subtitle")}</p>
          </div>
          <a
            href="https://kancha.pilotariak.com/"
            class="btn btn--primary web-callout__btn"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t("kancha.web.cta")}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ── Contribute ────────────────────────────────────────────── -->
    <section class="section" id="contribute" aria-label={t("kancha.contribute.title")}>
      <div class="container">
        <div class="contrib-layout">
          <div class="contrib-header reveal">
            <p class="eyebrow">{t("kancha.contribute.eyebrow")}</p>
            <h2 class="contrib-header__title">{t("kancha.contribute.title")}</h2>
            <p class="contrib-header__subtitle">{t("kancha.contribute.subtitle")}</p>
            <div class="contrib-header__actions">
              <a href="https://github.com/Pilotariak/kancha" class="btn btn--primary">
                {t("kancha.contribute.github")}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
              <a href={tp("/")} class="btn btn--secondary">
                {t("kancha.contribute.back")}
              </a>
            </div>
          </div>
          <div class="contrib-steps reveal reveal--delay-1">
            <div class="contrib-step">
              <div class="contrib-step__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M6 9l4 3-4 3M13 15h5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <h3 class="contrib-step__title">{t("kancha.contribute.step1.title")}</h3>
                <p class="contrib-step__desc">{t("kancha.contribute.step1.desc")}</p>
              </div>
            </div>
            <div class="contrib-step">
              <div class="contrib-step__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <h3 class="contrib-step__title">{t("kancha.contribute.step2.title")}</h3>
                <p class="contrib-step__desc">{t("kancha.contribute.step2.desc")}</p>
              </div>
            </div>
            <div class="contrib-step">
              <div class="contrib-step__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                  <circle cx="6" cy="6" r="3" stroke="currentColor" stroke-width="1.75"/>
                  <circle cx="6" cy="18" r="3" stroke="currentColor" stroke-width="1.75"/>
                  <circle cx="18" cy="9" r="3" stroke="currentColor" stroke-width="1.75"/>
                  <path d="M6 9v6M9 7.5l6-1.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <h3 class="contrib-step__title">{t("kancha.contribute.step3.title")}</h3>
                <p class="contrib-step__desc">{t("kancha.contribute.step3.desc")}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

<style>
  /* ── Hero ───────────────────────────────────────────────────── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 120px;
    padding-bottom: 0;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      var(--red) 0%,
      var(--red-dark) 45%,
      var(--cream) 100%
    );
    z-index: 0;
  }

  .hero__circle {
    position: absolute;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.07);
    pointer-events: none;
  }

  .hero__circle--1 { width: 420px; height: 420px; top: -80px; right: -80px; }
