import { useTranslations, type Lang } from '../i18n/utils';
import { statsData } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
const stats = statsData[lang];
---

<section class="section stats" id="stats" aria-labelledby="stats-title">
  <div class="container">
    <div class="stats__inner">
      <div class="stats__text reveal">
        <p class="eyebrow">{t('stats.eyebrow')}</p>
        <h2 class="stats__title" id="stats-title">
          {t('stats.title')}
        </h2>
        <p class="stats__subtitle">
          {t('stats.subtitle')}
        </p>
        <a href="#features" class="btn btn--primary stats__cta">
          {t('stats.cta')}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <dl class="stats__grid" aria-label={t('stats.ariaLabel')}>
        {
          stats.map((s, i) => (
            <div class={`stat-block reveal reveal--delay-${i + 1}`}>
              <dt>
                <span class="stat-block__value" aria-label={s.value}>
                  {s.value}
                </span>
                <span class="stat-block__label">{s.label}</span>
              </dt>
              <dd class="stat-block__desc">{s.description}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>

<style>
  .stats__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  /* Left text column */
  .stats__title {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -0.5px;
    margin-block: var(--space-md) var(--space-lg);
  }

  .stats__subtitle {
    font-size: 17px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
    max-width: 460px;
  }

  /* Right stats grid */
  .stats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .stat-block {
    background-color: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition:
      border-color 150ms ease,
      transform 200ms ease;
  }

  .stat-block:hover {
    border-color: var(--red-border);
    transform: translateY(-2px);
  }

  .stat-block__value {
    display: block;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 800;
    color: var(--red);
    line-height: 1;
    letter-spacing: -1px;
    margin-bottom: var(--space-2xs);
  }

  .stat-block__label {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    margin-bottom: var(--space-xs);
  }

  .stat-block__desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .stats__inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .stats__subtitle {
      max-width: none;
    }
  }

  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
