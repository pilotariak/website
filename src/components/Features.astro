import { useTranslations, type Lang } from '../i18n/utils';
import { featuresData } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

const featureIcons = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
    <path d="M16 2v4M8 2v4M3 10h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
  </svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke="currentColor" stroke-width="2"/>
    <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/>
  </svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
];

const features = featuresData[lang].map((text, i) => ({
  icon: featureIcons[i],
  ...text,
}));
---

<section class="section features" id="features" aria-labelledby="features-title">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">{t('features.eyebrow')}</p>
      <h2 class="section-header__title" id="features-title">
        {t('features.title')}
      </h2>
      <p class="section-header__subtitle">
        {t('features.subtitle')}
      </p>
    </div>

    <ul class="features__grid" role="list">
      {
        features.map((f, i) => (
          <li
            class={`feature-card reveal reveal--delay-${(i % 3) + 1}`}
            role="listitem"
          >
            <div class="feature-card__icon" aria-hidden="true">
              <Fragment set:html={f.icon} />
            </div>
            <p class="eyebrow feature-card__label">{f.label}</p>
            <h3 class="feature-card__title">{f.title}</h3>
            <p class="feature-card__body">{f.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .feature-card {
    background-color: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      transform 200ms ease;
  }

  .feature-card:hover {
    border-color: var(--red);
    box-shadow: var(--shadow) 0 4px 16px;
    transform: translateY(-2px);
  }

  .feature-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: var(--red-soft);
    border-radius: var(--radius-md);
    color: var(--red);
    margin-bottom: var(--space-xs);
    flex-shrink: 0;
  }

  .feature-card__label {
    color: var(--red);
    margin-bottom: 0;
  }

  .feature-card__title {
    font-size: 18px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.25;
    letter-spacing: -0.2px;
  }

  .feature-card__body {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    flex: 1;
  }

  @media (max-width: 1024px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
