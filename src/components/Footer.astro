import { useTranslations, useTranslatedPath, type Lang } from '../i18n/utils';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <a href={tp('/')} class="footer__logo" aria-label={t('footer.ariaHome')}>
      <svg
        width="24"
        height="24"
        viewBox="0 0 32 32"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="2"></circle>
        <path
          d="M16 4C16 4 10 10 10 16C10 22 16 28 16 28C16 28 22 22 22 16C22 10 16 4 16 4Z"
          fill="currentColor"
          opacity="0.2"></path>
        <circle cx="16" cy="16" r="5" fill="currentColor"></circle>
      </svg>
      <span>Pilotariak</span>
    </a>

    <p class="footer__copy">
      &copy; {year} Pilotariak — Open Source · Apache 2.0
    </p>

    <nav class="footer__links" aria-label={t('footer.ariaNav')}>
      <a href="https://github.com/Pilotariak" class="footer__link">GitHub</a>
      <a href={tp('/frontis')} class="footer__link">Frontis</a>
      <a href={tp('/kancha')} class="footer__link">Kancha</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background-color: var(--ink);
    padding-block: 64px;
    padding-inline: var(--container-pad);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--cream);
    letter-spacing: 1px;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  .footer__copy {
    font-size: 14px;
    color: var(--subtle);
    flex: 1;
  }

  .footer__links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__link {
    font-size: 14px;
    color: var(--subtle);
    transition: color 150ms ease;
  }

  .footer__link:hover {
    color: var(--cream);
  }

  @media (max-width: 640px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }

    .footer__copy {
      flex: none;
    }
  }
</style>
