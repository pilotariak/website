const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container footer__inner">
    <a href="/" class="footer__logo" aria-label="Pilotariak — Accueil">
      <svg
        width="24"
        height="24"
        viewBox="0 0 32 32"
        fill="none"
        aria-hidden="true"
      >
        <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="2"></circle>
        <path
          d="M16 4C16 4 10 10 10 16C10 22 16 28 16 28C16 28 22 22 22 16C22 10 16 4 16 4Z"
          fill="currentColor"
          opacity="0.2"></path>
        <circle cx="16" cy="16" r="5" fill="currentColor"></circle>
      </svg>
      <span>Pilotariak</span>
    </a>

    <p class="footer__copy">
      &copy; {year} Pilotariak — Open Source · Apache 2.0
    </p>

    <nav class="footer__links" aria-label="Liens du pied de page">
      <a href="https://github.com/Pilotariak" class="footer__link">GitHub</a>
      <a href="/frontis" class="footer__link">Frontis</a>
      <a href="/kancha" class="footer__link">Kancha</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background-color: var(--card);
    padding-block: var(--space-xl);
  }

  .footer__inner {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.2px;
    flex-shrink: 0;
  }

  .footer__copy {
    font-size: 13px;
    color: var(--muted);
    flex: 1;
  }

  .footer__links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__link {
    font-size: 13px;
    color: var(--muted);
    transition: color 150ms ease;
  }

  .footer__link:hover {
    color: var(--red);
  }

  @media (max-width: 600px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-md);
    }

    .footer__copy {
      flex: none;
    }
  }
</style>
